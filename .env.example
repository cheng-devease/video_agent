# 环境变量配置示例
# 复制此文件为 .env 并填写你的API密钥

# ==================== LLM API密钥 ====================
# OpenAI API密钥 (必需)
OPENAI_API_KEY=your_openai_api_key_here

# OpenAI API基础URL (可选，用于代理)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic API密钥 (可选)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ==================== 图像生成API密钥 ====================
# FLUX API密钥
FLUX_API_KEY=your_flux_api_key_here
FLUX_API_URL=https://api.fal.ai/v1/image

# Replicate API Token (可选)
# REPLICATE_API_TOKEN=your_replicate_token_here

# ==================== 视频生成API密钥 ====================
# fal.ai (Kling v3 Pro 图生视频当前使用这个)
FAL_API_KEY=your_fal_api_key_here

# Kling 直连配置保留兼容，目前不会用于视频生成
# KLING_API_KEY=your_kling_api_key_here
# KLING_API_URL=https://api.klingai.com

# Sora API (通常与OPENAI_API_KEY相同)
# SORA_API_KEY=your_sora_api_key_here

# Seedance/即梦 API
SEEDANCE_API_KEY=your_seedance_api_key_here
SEEDANCE_API_URL=https://api.jimeng.ai

# Google Veo3 API
VEO3_API_KEY=your_google_api_key_here
VEO3_PROJECT_ID=your_google_project_id

# ==================== 视频编辑API密钥 ====================
# OpusClip API (可选)
# OPUSCLIP_API_KEY=your_opusclip_api_key_here

# ==================== 云存储API密钥 ====================
# AWS配置 (可选)
# AWS_ACCESS_KEY=your_aws_access_key
# AWS_SECRET_KEY=your_aws_secret_key
# AWS_REGION=us-east-1
# S3_BUCKET=your_bucket_name

# Google Cloud凭据 (可选)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json
